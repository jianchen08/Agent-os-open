# ============================================
# 前端环境变量配置示例
# 复制此文件为 .env.local 并根据环境修改配置
# ============================================

# ============ API配置 ============
# 后端API基础URL
# 注意：本机开发请用 127.0.0.1 而非 localhost。
# Windows/部分系统下 localhost 会同时解析到 IPv6(::1)，若后端仅监听 IPv4，
# 每个请求会先在 ::1 上超时约 2s 再回退 IPv4，表现为"创建会话/打开页面极慢"。
#
# 容器模式（start_web_cn.bat / docker compose）下，浏览器访问前端容器，
# /api/* 请求由容器内 server.py 反代到 BACKEND_URL 环境变量指向的后端。
# 因此后端的实际端口由 compose 的 BACKEND_PORT 控制（默认 8988），与本文件的
# VITE_API_BASE_URL 无关——这里只在 npm run dev（非容器开发模式）时生效。
# 多实例运行时，后端端口通过环境变量 BACKEND_PORT 调整，无需改这里。
#
# 开发环境默认: http://127.0.0.1:8988
# 生产环境示例: https://api.example.com
VITE_API_BASE_URL=http://127.0.0.1:8988

# ============ WebSocket配置 ============
# WebSocket服务器基础URL（留空则从 VITE_API_BASE_URL 派生，http→ws）
# 开发环境默认: ws://127.0.0.1:8988
# 生产环境示例: wss://api.example.com
VITE_WS_BASE_URL=ws://127.0.0.1:8988

# ============ 应用配置 ============
# 应用标题
VITE_APP_TITLE=Agent工作流系统

# 应用版本
VITE_APP_VERSION=0.0.1

# ============ 开发模式配置 ============
# 是否使用Mock数据（开发调试用）
# true: 使用Mock数据，不连接真实后端
# false: 连接真实后端API
VITE_USE_MOCK=false

# ============ 认证配置 ============
# 令牌存储键名
VITE_ACCESS_TOKEN_KEY=access_token
VITE_REFRESH_TOKEN_KEY=refresh_token

# 令牌刷新阈值（秒）
# 当令牌剩余有效期小于此值时自动刷新
VITE_TOKEN_REFRESH_THRESHOLD=300

# ============ 日志配置 ============
# 日志级别: debug, info, warn, error
VITE_LOG_LEVEL=info

# 是否启用控制台日志
VITE_ENABLE_CONSOLE_LOG=true

# ============ 功能开关 ============
# 是否启用WebSocket实时通信
VITE_ENABLE_WEBSOCKET=true

# 是否使用 Streamdown 进行 Markdown 渲染
# true: 使用 Streamdown（优化流式输出，避免闪烁）
# false: 使用 react-markdown（传统实现）
VITE_USE_STREAMDOWN=false

# 是否使用统一的 ActivityCard 组件
# true: 使用新的 ActivityCard 组件（统一工具调用和任务卡片渲染）
# false: 使用旧的工具调用组件（向后兼容）
VITE_USE_UNIFIED_ACTIVITY_CARD=false

# 是否启用错误上报
VITE_ENABLE_ERROR_REPORTING=false

# 错误上报服务URL（如Sentry DSN）
VITE_ERROR_REPORTING_URL=

# ============ 性能配置 ============
# API请求超时时间（毫秒）
VITE_API_TIMEOUT=30000

# API请求重试次数
VITE_API_RETRY_COUNT=3

# WebSocket重连最大次数
VITE_WS_MAX_RETRIES=5

# WebSocket心跳间隔（毫秒）
VITE_WS_HEARTBEAT_INTERVAL=30000
