# =============================================================================
# AgentOS Environment Snapshot Image
# 用途: 包含完整 Python 后端依赖 + 前端 npm 依赖 + Playwright 浏览器
# 后续任务可基于此镜像创建工作空间，无需重复安装依赖
# =============================================================================

# 使用 node:18-bookworm-slim 作为基础镜像
# (Node 18 LTS 比 Node 20 在 WSL 虚拟化 CPU 上 V8 引擎更稳定)
FROM node:18-bookworm-slim

LABEL maintainer="Agent OS Team" \
      description="AgentOS 环境镜像快照 — Python deps + Frontend deps + Playwright" \
      version="1.0.0" \
      purpose="environment-snapshot"

# -----------------------------------------------------------------------------
# 0. 切换为国内 apt 镜像源 (清华 TUNA) — 官方源 500/502 不稳定
# -----------------------------------------------------------------------------
RUN sed -i 's|deb.debian.org|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null \
    || sed -i 's|deb.debian.org|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list

# -----------------------------------------------------------------------------
# 1. 系统依赖: 基础工具 + Python + Playwright 浏览器系统依赖
# -----------------------------------------------------------------------------
RUN for i in 1 2 3; do \
        apt-get update && break || sleep 5; \
    done \
    && for i in 1 2 3; do \
        apt-get install -y --no-install-recommends \
            git \
            curl \
            wget \
            ca-certificates \
            build-essential \
            gcc \
            # Python
            python3 \
            python3-pip \
            python3-venv \
            python3-full \
            # Playwright Chromium 系统依赖
            libnss3 \
            libnspr4 \
            libatk1.0-0 \
            libatk-bridge2.0-0 \
            libcups2 \
            libdrm2 \
            libdbus-1-3 \
            libxkbcommon0 \
            libxcomposite1 \
            libxdamage1 \
            libxfixes3 \
            libxrandr2 \
            libgbm1 \
            libpango-1.0-0 \
            libcairo2 \
            libasound2 \
            libatspi2.0-0 \
        && break || sleep 5; \
    done \
    && rm -rf /var/lib/apt/lists/*

# python -> python3 链接（确保 python 命令可用）
RUN ln -sf /usr/bin/python3 /usr/local/bin/python

# 验证 node/npm/python 版本
RUN node --version && npm --version && python3 --version && pip3 --version

# 配置 npm 使用国内镜像加速
RUN npm config set registry https://registry.npmmirror.com

# -----------------------------------------------------------------------------
# 2. 创建 Python 虚拟环境并安装项目 Python 依赖 (避免 PEP 668 问题)
# -----------------------------------------------------------------------------
WORKDIR /build

# 先复制依赖声明，利用 Docker 缓存层加速
COPY pyproject.toml ./

# 创建 venv 避免系统 pip PEP 668 限制
RUN python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/venv/bin/pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple \
    && /opt/venv/bin/pip config set global.trusted-host pypi.tuna.tsinghua.edu.cn \
    && /opt/venv/bin/pip install --no-cache-dir \
        "pyyaml>=6.0" \
        "rich>=13.0" \
        "aiohttp>=3.9" \
        "watchdog>=3.0" \
        "litellm>=1.0" \
        "pydantic>=2.0" \
        "jsonschema>=4.0" \
        "simpleeval>=1.0" \
        "python-lsp-server>=1.14.0" \
        "fastapi>=0.104.0" \
        "uvicorn[standard]>=0.24.0" \
        "pytest>=7.0" \
        "pytest-asyncio>=0.21" \
        "httpx>=0.27.0" \
        "ruff>=0.4.0" \
        "playwright>=1.40.0" \
    && /opt/venv/bin/pip check

# 将 venv 加入 PATH，后续 python/pip 都指向 venv
ENV PATH="/opt/venv/bin:${PATH}"
ENV VIRTUAL_ENV=/opt/venv

# -----------------------------------------------------------------------------
# 3. 安装前端 npm 依赖 (基于 frontend/package.json + package-lock.json)
# -----------------------------------------------------------------------------
WORKDIR /build/frontend

# 先复制 lockfile 以利用 Docker 缓存
COPY frontend/package.json frontend/package-lock.json ./

# 安装前端依赖 (含 devDependencies，因镜像快照需支持开发与构建)
# 用 node --no-opt 直接调用 npm，禁用 V8 优化层避免 WSL 虚拟化 CPU 上 avx512 SIGILL
# 拆分两步：先 --ignore-scripts 装全依赖，再单独跑 postinstall (patch 失败不影响镜像用途)
RUN node --no-opt $(which npm) ci --legacy-peer-deps --no-audit --no-fund --ignore-scripts \
    && node scripts/patch-lobehub-ui.mjs 2>/dev/null || echo "[warn] postinstall patch skipped (non-fatal for snapshot)" \
    && node --no-opt $(which npm) cache clean --force

# -----------------------------------------------------------------------------
# 4. 安装 Playwright Chromium 浏览器
# -----------------------------------------------------------------------------
# PLAYWRIGHT_BROWSERS_PATH 指定浏览器安装位置
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN for i in 1 2 3; do \
        playwright install chromium && break || sleep 10; \
    done

# -----------------------------------------------------------------------------
# 5. 设置工作目录与元数据
# -----------------------------------------------------------------------------
WORKDIR /workspace

# 健康检查：验证 Python 包、Node、Chromium 都在位
# Chromium 路径匹配 chrome-linux*（带或不带 64 后缀，适配不同 Playwright 版本）
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "import yaml, pydantic, fastapi; print('python ok')" \
        && node --version \
        && ls /ms-playwright/chromium-*/chrome-linux*/chrome >/dev/null 2>&1 \
        || exit 1

CMD ["/bin/bash"]
