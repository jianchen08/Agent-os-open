# 开发环境配置
APP_DEBUG=true
APP_ENVIRONMENT=development

# 事件总线配置（memory | redis_streams）
EVENT_BUS_TYPE=memory

# Redis 配置
# 用于 TokenManager 的 token 撤销存储（access/refresh 共用，跨进程生效）。
# docker-compose 中 redis 映射端口可能不同，按实际部署调整。
REDIS_URL=redis://localhost:6480/0

# 使用 SQLite 数据库
APP_DATABASE_URL=sqlite+aiosqlite:///database.db

# JWT 配置（生产环境务必更换为高强度随机值）
APP_JWT_SECRET_KEY=change-me-to-a-random-secret
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=7

# 日志配置
LOG_LEVEL=DEBUG
APP_LOG_FORMAT=text

# 注入 LLM 的当前时间所用时区（IANA 时区名）
# 取值如 Asia/Shanghai、UTC、Asia/Tokyo、America/New_York。默认 Asia/Shanghai。
# 传给 LLM 的时间会带上时区标注，格式如：2026-07-02 11:24:00 (UTC+8, Asia/Shanghai)
APP_TIMEZONE=Asia/Shanghai

# 智谱 AI (GLM) API Key —— 主备双 key，主 key 优先使用
# 获取地址：https://open.bigmodel.cn/
# llm.yaml 中通过 ${ZHIPU_API_KEY} / ${ZHIPU_API_KEY_2} 引用
APP_ZHIPU_API_KEY=your-zhipu-primary-api-key
ZHIPU_API_KEY=your-zhipu-primary-api-key
ZHIPU_API_KEY_2=your-zhipu-backup-api-key

# LLM 并发控制配置（按提供商）
LLM_ZHIPU_MAX_CONCURRENT=2
LLM_OPENAI_MAX_CONCURRENT=10
LLM_ANTHROPIC_MAX_CONCURRENT=5
LLM_DEFAULT_MAX_CONCURRENT=2

# 向后兼容（已弃用）
LLM_MAX_CONCURRENT=2
LLM_RATE_LIMIT_PER_MINUTE=60

# MiniMax API Key（如不使用可留空）
# 获取地址：https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key

# 默认管理员密码
# 系统启动时，会为内置 admin 账号设置此密码（bcrypt 哈希后存入内存）。
# 若不配置，将回退到一个不可用的字面默认值（含 $(date +%s)，Python 不会展开它），
# 导致 admin 无法登录、POST /api/v1/auth/login 一律 401。
# 仅在进程启动时读取一次，修改后必须重启后端才生效。
# 生产环境务必改为高强度随机密码。
DEFAULT_ADMIN_PASSWORD=your-admin-password
